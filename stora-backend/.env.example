# ──────────────────────────────────────────────────────────────
# Stora Backend – Environment Configuration Template
# Copy this file to .env and fill in the values for your setup.
# ──────────────────────────────────────────────────────────────

# Application environment: "local" or "production"
APP_ENV=local

# PostgreSQL connection parameters
POSTGRES_USER=stora_user
POSTGRES_PASSWORD=stora_password
POSTGRES_DB=stora_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Assembled database URL (overrides individual params if set)
# For local Docker: postgresql+asyncpg://stora_user:stora_password@db:5432/stora_db
# For production  : set this to your managed database connection string
# DATABASE_URL=

# JWT Authentication
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
